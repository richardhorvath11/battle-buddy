#!/usr/bin/env python3
"""CLI shim for bb_validate (research R7): one implementation serves both
import-style callers (hooks, tests, later slices) and shell-outs from skills.
Exit codes: 0 pass / 1 violation(s) / 2 usage error."""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

from bb_validate import main

if __name__ == "__main__":
    sys.exit(main())
